   <script define:vars={{ questions }}>
      const startScreen = document.getElementById("start-screen");
      const quizScreen = document.getElementById("quiz-screen");
      const resultScreen = document.getElementById("result-screen");

      const startBtn = document.getElementById("start-btn");
      const restartBtn = document.getElementById("restart-btn");

      const questionTitle = document.getElementById("question-title");
      const answersContainer = document.getElementById("answers");

      const progressText = document.getElementById("progress-text");
      const progressBar = document.getElementById("progress-bar");

      let currentQuestion = 0;

      let scores = {
         SIDDIQ: 0,
         AMANAH: 0,
         FATHANAH: 0,
         TABLIGH: 0,
      };

      const results = {
         SIDDIQ: {
            subtitle: "The Principled Leader",
            description:
               "Kamu adalah pemimpin yang menjunjung tinggi integritas, kejujuran, dan konsistensi antara ucapan dan tindakan.",
         },
         AMANAH: {
            subtitle: "The Guardian Leader",
            description:
               "Kamu memiliki rasa tanggung jawab yang tinggi dan dipercaya menjaga amanah serta kepentingan tim.",
         },
         FATHANAH: {
            subtitle: "The Strategist Leader",
            description:
               "Kamu unggul dalam berpikir strategis, menganalisis situasi, dan menemukan solusi inovatif.",
         },
         TABLIGH: {
            subtitle: "The Inspiring Communicator",
            description:
               "Kamu mampu menyampaikan ide dengan jelas, membangun hubungan yang kuat, dan menginspirasi orang lain.",
         },
      };

      function renderQuestion() {
         const q = questions[currentQuestion];

         questionTitle.textContent = q.question;

         progressText.textContent = `${currentQuestion + 1} / ${questions.length}`;

         progressBar.style.width = `${((currentQuestion + 1) / questions.length) * 100}%`;

         answersContainer.innerHTML = "";

         q.options.forEach((option) => {
            const button = document.createElement("button");

            button.className =
               "w-full text-left p-4 rounded-xl border border-gray-200 hover:border-primary hover:bg-primary-50 active:scale-[0.98] active:border-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary transition-all duration-200";

            button.textContent = option.text;

            button.addEventListener("click", () => {
               scores[option.type]++;

               currentQuestion++;

               if (currentQuestion < questions.length) {
                  renderQuestion();
               } else {
                  showResult();
               }
            });

            answersContainer.appendChild(button);
         });
      }

      function showResult() {
         quizScreen.classList.add("hidden");
         resultScreen.classList.remove("hidden");

         const winner = Object.keys(scores).reduce((a, b) =>
            scores[a] > scores[b] ? a : b,
         );

         document.getElementById("result-title").textContent = winner;
         document.getElementById("result-subtitle").textContent =
            results[winner].subtitle;

         document.getElementById("result-description").textContent =
            results[winner].description;
      }

      function resetQuiz() {
         currentQuestion = 0;

         scores = {
            SIDDIQ: 0,
            AMANAH: 0,
            FATHANAH: 0,
            TABLIGH: 0,
         };

         resultScreen.classList.add("hidden");
         startScreen.classList.remove("hidden");
      }

      startBtn.addEventListener("click", () => {
         startScreen.classList.add("hidden");
         quizScreen.classList.remove("hidden");
         renderQuestion();
      });

      restartBtn.addEventListener("click", resetQuiz);
   </script>

